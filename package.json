{
  "name": "md-slide-studio-monorepo",
  "version": "0.3.3",
  "private": true,
  "type": "module",
  "description": "Markdown原稿からスライドHTML／PDF／PNGを生成するWebアプリ（monorepo）",
  "workspaces": [
    "packages/core",
    "packages/app"
  ],
  "scripts": {
    "dev": "npm run dev -w @mdss/app",
    "build": "npm run build -w @mdss/core && npm run build -w @mdss/app",
    "preview": "npm run preview -w @mdss/app",
    "lint": "eslint packages/*/src",
    "lint:fix": "eslint packages/*/src --fix",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx,css}\"",
    "test": "npm run test -w @mdss/core && npm run test -w @mdss/app",
    "test:core": "npm run test -w @mdss/core",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc -p packages/core/tsconfig.json --noEmit && tsc -p packages/app/tsconfig.json --noEmit",
    "verify": "npm run typecheck && npm test && npm run lint && npm run test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.63.0"
  }
}
