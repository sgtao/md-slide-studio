{
  "name": "mdss-convert",
  "version": "0.4.1",
  "description": "CLI that converts MD-Slide-Studio markdown into standalone HTML",
  "type": "module",
  "bin": {
    "mdss-convert": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node build.mjs",
    "test": "node build.mjs && node --test test/smoke.test.mjs",
    "prepack": "node scripts/clean-tgz.mjs && node build.mjs",
    "pack:dist": "npm pack --pack-destination ./dist"
  },
  "keywords": [
    "markdown",
    "slides",
    "html",
    "presentation",
    "mdss"
  ],
  "license": "MIT",
  "devDependencies": {
    "@mdss/core": "*",
    "@mdss/app": "*",
    "esbuild": "^0.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yaml": "^2.5.0",
    "zod": "^4.4.3"
  }
}
