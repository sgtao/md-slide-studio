{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "jsx": "react-jsx",
    "types": ["node"],
    "paths": {
      "@mdss/core": ["../core/src/index.ts"],
      "@mdss/app-ssr": ["../app/src/ssr.tsx"]
    },
    "noEmit": true
  },
  "include": ["src", "build.mjs"]
}
